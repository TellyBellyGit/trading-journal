// prisma/schema.prisma
// 1. Define the database
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2. Set generator for Prisma Client
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// 3. Define the User model
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // Hashed password
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  // Optional user preferences
  timezone  String?  @default("UTC")
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Relations
  brokers   Broker[]
  trades    Trade[]
  notes     Note[]
}

// 4. Define the Broker model
model Broker {
  id          Int     @id @default(autoincrement())
  name        String  // e.g., "TD Ameritrade", "Interactive Brokers" (removed @unique for multi-user)
  displayName String  // e.g., "TD Ameritrade - Main Account"
  accountType String? // e.g., "IRA", "Taxable", "Business"
  accountId   String? // Broker's account identifier
  isActive    Boolean @default(true)
  // Commission structure (optional)
  defaultCommission Float?       // Default commission per trade
  commissionType    String?      // "per_trade", "per_share", "percentage"
  // User relationship
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Relations
  trades      Trade[]
  
  // Unique constraint: user can't have duplicate broker names
  @@unique([userId, name])
}

// 5. Define the Trade model
model Trade {
  id            Int      @id @default(autoincrement())
  symbol        String
  direction     String
  quantity      Int
  entryDate     DateTime
  entryTime     String
  entryPrice    Float
  exitDate      DateTime
  exitTime      String
  exitPrice     Float
  duration      String
  pnl           Float
  percentChange Float
  orderType     String
  assessment    String?
  capital       Float
  status        String?  @default("Closed")
  // User relationship
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Broker relationship
  brokerId      Int
  broker        Broker   @relation(fields: [brokerId], references: [id])
  // Rich text journaling fields
  notes         String?  // Rich text content (HTML format from Tiptap)
  strategy      String?  // Trading strategy used
  riskReward    String?  // Risk:Reward ratio (e.g., "1:3")
  commission    Float?   // Actual commission/fees paid (can override broker default)
  tags          String?  // Comma-separated tags for categorization
  // Additional trade metadata
  tradeId       String?  // Broker's trade confirmation number
  executionVenue String? // Where trade was executed (e.g., "NASDAQ", "NYSE")
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Performance indexes
  @@index([userId])                    // Critical: user-scoped queries
  @@index([userId, entryDate])         // Critical: user trades by date
  @@index([userId, status])            // User trades by status
  @@index([userId, symbol])            // User trades by symbol
  @@index([brokerId])                  // Broker-scoped queries
  @@index([entryDate])                 // Date range queries
}

// 6. Define the Note model
model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   // Rich text content (HTML format from Tiptap)
  category  String?  // Optional category for organization
  tags      String?  // Comma-separated tags for categorization
  // User relationship
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Performance indexes
  @@index([userId])                    // Critical: user-scoped queries
  @@index([userId, createdAt])         // User notes by date
  @@index([category])                  // Notes by category
}