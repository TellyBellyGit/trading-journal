{
  "name": "trading-journal-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "build": "tsc",
    "start": "npx prisma generate && npx prisma migrate deploy && node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "migrate-brokers": "npx prisma db push --accept-data-loss && npx ts-node scripts/postMigrationSetup.ts",
    "build-with-migration": "npm run migrate-brokers && npm run build",
    "create-admin": "node scripts/createAdmin.js",
    "cleanup-users": "node scripts/cleanupUsers.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^6.8.2",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "node-fetch": "^2.7.0",
    "openai": "^5.13.1",
    "pg": "^8.21.0",
    "resend": "^4.7.0",
    "stripe": "^18.3.0",
    "trading-journal": "file:..",
    "yahoo-finance2": "^3.14.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.15.4",
    "nodemon": "^3.1.10",
    "prisma": "^6.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.93.1"
  }
}
