{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/components/Archive/**/*", "src/WorkingApp.tsx", "src/Applatest.tsx", "src/components/NoFilterAllTrades.tsx", "src/components/ImportTrades.tsx", "src/components/auth/old_shit_register.tsx"]
}
